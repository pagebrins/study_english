PORT=9090
DB_DRIVER=mysql
DB_PATH=study_english.db
MYSQL_DSN=qa:123456@tcp(127.0.0.1:3306)/study_english?charset=utf8mb4&parseTime=True&loc=Local
JWT_SECRET=change-this-secret
DOUBAO_API_KEY=
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL_GENERATE_QUESTIONS=seed-2-0-pro
LLM_MODEL_SUBMIT_ANSWER=seed-2-0-pro
LLM_MODEL_CHAT=seed-2-0-pro
LLM_PROMPT_FILE=backend/prompts/generate_questions.md
