PORT=9090
DB_DRIVER=mysql
DB_PATH=study_english.db
MYSQL_DSN=qa:123456@tcp(127.0.0.1:3306)/study_english?charset=utf8mb4&parseTime=True&loc=Local
JWT_SECRET=change-this-secret
LLM_API_KEY=
LLM_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
LLM_MODEL_GENERATE_QUESTIONS=glm-4.6:cloud
LLM_MODEL_SUBMIT_ANSWER=glm-4.6:cloud
LLM_MODEL_CHAT=glm-4.6:cloud
LLM_PROMPT_FILE=backend/prompts/generate_questions.md
LLM_ANALYZE_PROMPT_FILE=backend/prompts/analyze_answer.md
LLM_CHAT_PROMPT_FILE=backend/prompts/explain_chat.md
LLM_STREAM_ENABLED=true
PREHEAT_ENABLED=true
PREHEAT_INTERVAL_SEC=10
PREHEAT_SERVED_TIMEOUT_MIN=30
PREHEAT_TARGET_WORD_SENTENCE=100
PREHEAT_TARGET_ARTICLE=3
